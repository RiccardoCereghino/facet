// Generated by facet. Edited copies belong in <workspaces>/.tools/issue-layout.kdl,
// which facet prefers when it exists.
//
// Placeholders: __CWD__ the home clone, __WS__ the workspace, __AGENT__ the agent
// command, __NUM__ the issue number. Backslashes are escaped for KDL.
layout {
    cwd "__CWD__"

    tab name="#__NUM__" focus=true {
        pane split_direction="vertical" {
            pane size="60%" name="agent" {
                command "__AGENT__"
            }
            pane size="40%" name="shell"
        }
    }

    tab name="workspace" {
        pane cwd="__WS__" name="workspace"
    }
}
