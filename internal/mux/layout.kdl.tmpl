// Generated by facet. Edited copies belong in <workspaces>/.tools/issue-layout.kdl,
// which facet prefers when it exists.
//
// Placeholders: __CWD__ the home clone, __WS__ the workspace, __NUM__ the issue
// number, __AGENT_CMD__ the shell that starts the agent, __AGENT_ARGS__ its args.
// Backslashes are escaped for KDL.
//
// cwd is set on every pane, not once at the top: a top-level cwd is ignored when
// a layout is added as tabs to an existing session.
//
// The agent runs THROUGH a shell. zellij's Windows backend calls CreateProcessW
// directly, so it cannot start a shell script or a .cmd shim -- and when the
// spawn fails it panics, taking the whole session down with it.
layout {
    tab name="#__NUM__" focus=true {
        pane split_direction="vertical" {
            pane size="60%" name="agent" cwd="__CWD__" {
                command "__AGENT_CMD__"
                __AGENT_ARGS__
            }
            pane size="40%" name="shell" cwd="__CWD__"
        }
    }

    tab name="workspace" {
        pane cwd="__WS__" name="workspace"
    }
}
